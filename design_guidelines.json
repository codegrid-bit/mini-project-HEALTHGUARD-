  "universal_guidelines": [
    "Do not use generic gradients. Use subtle, organic mesh gradients if needed.",
    "Ensure all text has high contrast (WCAG AA).",
    "Use 'sonner' for all toast notifications.",
    "All interactive elements must have 'data-testid'.",
    "Use 'Manrope' for headings and 'Inter' for body text.",
    "Primary buttons should be pill-shaped (rounded-full).",
    "Dashboard cards should have a subtle hover lift effect.",
    "Avoid 'clinical' stark white; use warm off-whites for backgrounds."
  ],
  "instructions_to_main_agent": {
    "setup": [
      "Install 'lucide-react' for icons.",
      "Install 'recharts' for data visualization (health history).",
      "Install 'framer-motion' for smooth transitions.",
      "Configure Tailwind with the custom colors provided."
    ],
    "implementation_order": [
      "Setup Layouts (Landing, Auth, Dashboard Shell)",
      "Build Components (Quiz Card, Risk Meter, Upload Form)",
      "Integrate Pages (Home, Quiz, Results, History)",
      "Add Polish (Animations, Toasts, Loading States)"
    ]
  }
